<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.itwillbs.persistence.AdminInquiryDAO">

  <select id="getAllInquiries" resultType="com.itwillbs.domain.InquiryVO">
    SELECT * FROM inquiry ORDER BY created_at DESC
  </select>

  <select id="getInquiry" resultType="com.itwillbs.domain.InquiryVO">
    SELECT * FROM inquiry WHERE inquiry_id = #{inquiry_id}
  </select>

  <select id="getResponse" resultType="com.itwillbs.domain.ResponseVO">
    SELECT * FROM response WHERE inquiry_id = #{inquiry_id}
  </select>

  <insert id="insertResponse">
    INSERT INTO response (inquiry_id, ad_id, response_content, created_at)
    VALUES (#{inquiry_id}, #{ad_id}, #{response_content}, NOW())
  </insert>

  <update id="updateResponse">
    UPDATE response
    SET response_content = #{response_content}
    WHERE response_id = #{response_id}
  </update>

  <delete id="deleteResponse">
    DELETE FROM response WHERE response_id = #{response_id}
  </delete>

</mapper>
  