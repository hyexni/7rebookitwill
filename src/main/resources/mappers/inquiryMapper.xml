<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
         "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
         
<mapper namespace="com.itwillbs.mapper.inquiryMapper">

	<!-- 1) 결과매핑 : InquiryVO 필드 - 컬럼 매핑 -->
	<resultMap id="inquiryResultMap" type="com.itwillbs.domain.InquiryVO">
		<id	property="inquiry_id" column="inquiry_id" />
		<result property="member_idx" column="member_idx" />
		<result property="title" column="title" />
		<result property="content" column="content" />
		<result property="status" column="status" />
		<result property="created_at" column="created_at" />
	</resultMap>
	
	<!-- 2) INSERT : 새 문의 등록 -->
	<insert id = "insertInquiry"
			parameterType="com.itwillbs.domain.InquiryVO"
			useGeneratedKeys="true"
			keyProperty="inquiry_id">
		Insert into inquiry
		 (member_idx, title, content, status, created_at)
		values
		 (#{member_idx}, #{title}, #{content}, #{status}, #{created_at})
	</insert>
	
	
	<!-- 3) SELECT ALL : 전제 목록 조회 -->
	
	
	
	<!-- 4) SELECT ONE : 상세 조회 -->


</mapper>


















