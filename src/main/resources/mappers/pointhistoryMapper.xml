<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.itwillbs.persistence.PointHistoryDAO">

 <!-- 사용자 모드 -->
    <select id="getPointHistory" resultType="com.itwillbs.dto.PointHistoryDTO">
        SELECT * FROM point
        WHERE member_idx = #{member_idx}
        ORDER BY change_date DESC, point_id DESC
    </select>

    <select id="getTotalPoints" resultType="java.lang.Integer">
        SELECT COALESCE(SUM(change_amount), 0)
        FROM point
        WHERE member_idx = #{memberIdx}
    </select>
     
